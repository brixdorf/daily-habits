# Copy this file to .env and fill in real values before starting the app.

# Port the app listens on (default: 3000)
PORT=3005

# A long random string used to sign session cookies — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string

# Login credentials for the single admin user.
# ADMIN_USERNAME: whatever username you want to log in with
ADMIN_USERNAME=admin

# ADMIN_PASSWORD_HASH: bcrypt hash of your chosen password — generate with:
#   node -e "const b=require('bcrypt'); b.hash('yourpassword', 12).then(console.log)"
# (run this once after npm install, then paste the output here)
ADMIN_PASSWORD_HASH=$2b$12$replacethiswithyourrealhash

# Set to "true" when running behind HTTPS (enables secure cookies)
# Leave unset or "false" for local development over HTTP
SECURE_COOKIES=false
